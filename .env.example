# =============================================================
# WhatsApp Team Manager — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=wmuser
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=whatsapp_manager
DATABASE_URL=postgresql://wmuser:change_me_strong_password@postgres:5432/whatsapp_manager

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Auth ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=change_me_very_long_random_secret_key_here

# ── Evolution API ─────────────────────────────────────────────
EVOLUTION_API_URL=https://your-evolution-api.com
EVOLUTION_API_KEY=your_evolution_api_key
EVOLUTION_INSTANCE=your_instance_name

# ── Webhook ───────────────────────────────────────────────────
# Secret to validate incoming webhooks from Evolution API
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=change_me_webhook_secret

# ── Application ───────────────────────────────────────────────
NEXTAUTH_URL=https://yourdomain.com
NODE_ENV=production

# ── Admin Seed ────────────────────────────────────────────────
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=Admin@123456
