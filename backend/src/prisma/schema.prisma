generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(MEMBER)
  color     String   @default("#25D366")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversations ConversationAssignment[]
  messages      Message[]
  metrics       DailyMetric[]
  notes         ConversationNote[]

  @@map("users")
}

enum Role {
  ADMIN
  MEMBER
}

model Contact {
  id         String    @id @default(uuid())
  phone      String    @unique
  name       String?
  profilePic String?
  lastSeen   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  conversations Conversation[]

  @@map("contacts")
}

model Conversation {
  id            String             @id @default(uuid())
  contactId     String
  contact       Contact            @relation(fields: [contactId], references: [id])
  status        ConversationStatus @default(OPEN)
  lastMessage   String?
  lastMessageAt DateTime?
  unreadCount   Int                @default(0)
  tags          String[]           @default([])
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  assignment        ConversationAssignment?
  messages          Message[]
  assignmentHistory AssignmentHistory[]
  notes             ConversationNote[]

  @@map("conversations")
}

enum ConversationStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  WAITING
}

model ConversationAssignment {
  id             String       @id @default(uuid())
  conversationId String       @unique
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  assignedAt     DateTime     @default(now())
  assignedBy     String

  @@map("conversation_assignments")
}

model AssignmentHistory {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  userId         String
  userName       String
  assignedBy     String
  assignedByName String
  assignedAt     DateTime     @default(now())
  unassignedAt   DateTime?

  @@map("assignment_history")
}

model Message {
  id             String        @id @default(uuid())
  conversationId String
  conversation   Conversation  @relation(fields: [conversationId], references: [id])
  evolutionId    String?       @unique
  content        String
  type           MessageType   @default(TEXT)
  direction      Direction
  sentById       String?
  sentBy         User?         @relation(fields: [sentById], references: [id])
  mediaUrl       String?
  mimeType       String?
  fileName       String?
  status         MessageStatus @default(SENT)
  timestamp      DateTime
  createdAt      DateTime      @default(now())

  @@index([conversationId, timestamp])
  @@map("messages")
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  STICKER
  REACTION
  LOCATION
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

model ConversationNote {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  content        String
  createdAt      DateTime     @default(now())

  @@map("conversation_notes")
}

model DailyMetric {
  id                   String   @id @default(uuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id])
  date                 DateTime @db.Date
  conversationsHandled Int      @default(0)
  messagesSent         Int      @default(0)
  avgResponseTimeMs    Int      @default(0)
  resolvedCount        Int      @default(0)

  @@unique([userId, date])
  @@map("daily_metrics")
}

model Settings {
  id                      String            @id @default(uuid())
  evolutionApiUrl         String            @default("")
  evolutionApiKey         String            @default("")
  evolutionInstance       String            @default("")
  assignmentMode          AssignmentMode    @default(ROUND_ROBIN)
  autoAssign              Boolean           @default(true)
  slaWarningMinutes       Int               @default(30)
  slaCriticalMinutes      Int               @default(60)
  allowMembersOverride    Boolean           @default(false)
  updatedAt               DateTime          @updatedAt

  @@map("settings")
}

enum AssignmentMode {
  ROUND_ROBIN
  LEAST_BUSY
  MANUAL
}
